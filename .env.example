# 複製此檔為 .env，填入你的金鑰。.env 已被 .gitignore 忽略，切勿提交到 GitHub。

# Google Maps（Maps JavaScript API）金鑰
# 申請與保護步驟見 docs/計畫書.md「八、Google Maps API Key 申請教學」
VITE_GOOGLE_MAPS_API_KEY=

# Supabase 專案設定（Project Settings → API）
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# 僅供匯入腳本（npm run import:taipei）使用的後端金鑰，切勿放進前端或提交。
# Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=
